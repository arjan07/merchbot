{
  "name": "merchbot",
  "version": "1.3.0",
  "description": "A bot to ping a channel in Discord when an item is refreshed on a Shopify store",
  "main": "dist/index.js",
  "scripts": {
    "build": "tsc --project .",
    "watch": "tsc -w",
    "start": "npm run build && node ./dist/index.js",
    "lint": "eslint . --ext .ts,.js",
    "lint:fix": "eslint . --ext .ts,.js --fix"
  },
  "type": "module",
  "engines": {
    "node": "24.x"
  },
  "keywords": [
    "discord",
    "shopify",
    "bot"
  ],
  "bugs": {
    "url": "https://github.com/arjan07/merchbot/issues"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/arjan07/merchbot.git"
  },
  "homepage": "https://github.com/arjan07/merchbot#readme",
  "author": "arjan07",
  "license": "GNU GPLv3",
  "devDependencies": {
    "@eslint/js": "^9.39.2",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-import": "^2.32.0",
    "eslint-plugin-prettier": "^5.5.5",
    "globals": "^17.4.0",
    "prettier": "^3.8.1",
    "typescript": "^6.0.2",
    "typescript-eslint": "^8.58.0"
  },
  "dependencies": {
    "cron-schedule": "^6.0.0",
    "deep-object-diff": "^1.1.9",
    "discord-api-types": "^0.38.44",
    "discord.js": "^14.26.2"
  }
}
